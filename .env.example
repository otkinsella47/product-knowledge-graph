# Required for persisted graph API routes in local development and deployed alpha.
# Apply db/schema.sql to this database before starting the app.
DATABASE_URL=postgres://user:password@localhost:5432/product_knowledge_graph

# Hosted alpha access. Use placeholders only; never commit real tokens.
ALPHA_AUTH_ENABLED=false
ALPHA_ANONYMOUS_WORKSPACE_ENABLED=true
ALPHA_ACCESS_TOKEN=
ALPHA_USER_EMAIL=
# Optional multiple-user form: token-one:user@example.com,token-two:other@example.com
ALPHA_AUTH_TOKENS=
